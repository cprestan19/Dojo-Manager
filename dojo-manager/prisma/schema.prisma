// Schema: DojoManager — SaaS de gestión de dojos de karate
// Desarrollado por Cristhian Paul Prestán — 2025

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dojo {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?  @db.Text
  ownerName String?
  phone     String?
  slogan    String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Parámetros de recordatorios de pago
  reminderToleranceDays Int     @default(5)
  lateInterestPct       Float   @default(10.0)
  autoRemindersEnabled  Boolean @default(false)
  loginBgImage          String? @db.Text @map("login_bg_image")

  users           User[]
  students        Student[]
  katas           Kata[]
  schedules       Schedule[]
  beltVideos      BeltVideo[]
  rolePermissions DojoRolePermission[]

  @@map("dojos")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role               String   @default("user")   // sysadmin, admin, user, student
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  photo     String?  @db.Text

  dojoId    String?  @map("dojo_id")
  dojo      Dojo?    @relation(fields: [dojoId], references: [id])

  studentId String?  @unique @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id])

  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  @@index([email])
  @@index([dojoId])
  @@index([dojoId, active])      // filter active users within a dojo
  @@index([dojoId, role])        // count/filter by role within a dojo (last-sysadmin checks)
  @@map("users")
}

model Student {
  id          String   @id @default(cuid())
  studentCode Int?     @unique

  dojoId    String   @map("dojo_id")
  dojo      Dojo     @relation(fields: [dojoId], references: [id])

  fullName   String   @default("") @map("full_name")
  firstName  String
  lastName   String
  cedula       String?
  fepakaId     String?  @map("fepaka_id")
  ryoBukaiId   String?  @map("ryo_bukai_id")
  photo        String?  @db.Text
  birthDate  DateTime
  gender     String
  nationality String

  condition           String?
  bloodType           String?  @map("blood_type")
  hasPrivateInsurance Boolean  @default(false)
  insuranceName       String?
  insuranceNumber     String?  @map("insurance_number")

  motherName  String?
  motherPhone String?
  motherEmail String?

  fatherName  String?
  fatherPhone String?
  fatherEmail String?

  address String? @db.Text

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Absence risk level — updated when attendance is recorded or via batch recalculation.
  // ACTIVO  : attended within last 3 days
  // ALERTA  : 3–13 days without attendance  (risk of disengagement)
  // RIESGO  : 14+ days without attendance  (high dropout risk)
  attendanceStatus String @default("ACTIVO") @map("attendance_status")

  portalUser        User?
  inscription       Inscription?
  payments          Payment[]
  beltHistory       BeltHistory[]
  attendances       Attendance[]
  studentSchedules  StudentSchedule[]
  kataCompetitions  KataCompetition[]

  @@index([dojoId, active])
  @@index([dojoId, lastName, firstName])
  @@index([dojoId, fullName])
  @@index([dojoId, active, fullName])
  @@map("students")
}

model Inscription {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  inscriptionDate   DateTime
  annualPaymentDate DateTime?

  annualAmount   Float  @default(0)
  monthlyAmount  Float  @default(0)
  discountAmount Float  @default(0)
  discountNote   String?

  // Pago quincenal (cada 15 días — 1° y 15 de cada mes)
  // paymentPeriod defaults to "monthly" so existing students are unaffected.
  paymentPeriod  String @default("monthly") @map("payment_period")  // monthly | biweekly
  biweeklyAmount Float  @default(0)          @map("biweekly_amount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inscriptions")
}

model Payment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  type     String
  amount   Float
  dueDate  DateTime
  paidDate DateTime?

  status       String  @default("pending")
  note         String?
  reminderSent Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([studentId, type, dueDate])
  @@index([studentId])
  @@index([studentId, status, dueDate])
  @@index([status, dueDate])
  @@index([reminderSent, status, dueDate])
  @@map("payments")
}

model Kata {
  id          String  @id @default(cuid())
  name        String
  beltColor   String
  order       Int     @default(0)
  description String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())

  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])

  beltHistory      BeltHistory[]
  kataCompetitions KataCompetition[]

  @@unique([name, dojoId])
  @@index([dojoId])
  @@index([beltColor])
  @@index([dojoId, active])      // GET /api/katas?active=1 filtered by dojo
  @@map("katas")
}

model BeltHistory {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  beltColor  String
  changeDate DateTime
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  isRanking  Boolean  @default(false)
  notes      String?

  createdAt DateTime @default(now())

  @@index([studentId, changeDate])
  @@map("belt_history")
}

model Schedule {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  name        String
  days        String
  startTime   String
  endTime     String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attendances      Attendance[]
  studentSchedules StudentSchedule[]
  @@index([dojoId])
  @@index([dojoId, active])      // filter active schedules within a dojo
  @@map("schedules")
}

model Attendance {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId  String?
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  type        String
  markedAt    DateTime  @default(now())
  note        String?
  corrected   Boolean   @default(false)
  correctedBy String?
  createdAt   DateTime  @default(now())
  @@index([studentId, markedAt])
  @@index([scheduleId, markedAt])
  @@index([studentId, type, markedAt])  // duplicate-entry check: WHERE studentId=? AND type=? AND markedAt >= ?
  @@map("attendances")
}

model StudentSchedule {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId String
  schedule   Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  @@index([studentId])
  @@index([scheduleId])
  @@index([assignedAt])
  @@index([studentId, removedAt])  // active assignments: WHERE studentId=? AND removedAt IS NULL
  @@map("student_schedules")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  userEmail String?
  dojoId    String?
  dojoSlug  String?
  ip        String?
  userAgent String?  @db.Text
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model EmailSettings {
  id        String   @id @default("singleton")
  host      String   @default("")
  port      Int      @default(587)
  user      String   @default("")
  password  String   @default("")
  secure    Boolean  @default(false)
  fromName  String   @default("DojoManager")
  updatedAt DateTime @updatedAt
  @@map("email_settings")
}

model DojoRolePermission {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  roleName    String   @map("role_name")
  roleLabel   String   @map("role_label")
  roleColor   String   @default("blue") @map("role_color")
  isSystem    Boolean  @default(false)  @map("is_system")
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dojoId, roleName])
  @@index([dojoId])
  @@map("dojo_role_permissions")
}

model BeltVideo {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  beltColor   String   @map("belt_color")
  title       String
  description String?  @db.Text
  videoUrl    String   @map("video_url")
  publicId    String   @map("public_id")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dojoId])
  @@index([dojoId, beltColor])
  @@map("belt_videos")
}

model KataCompetition {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  date       DateTime
  tournament String?
  result     String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([date])
  @@map("kata_competitions")
}
