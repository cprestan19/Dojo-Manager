# ─────────────────────────────────────────────────────────────
# Dojo Master — Variables de Entorno (PLANTILLA)
# 1. Copia este archivo:  cp .env.example .env.local
# 2. Rellena los valores reales (nunca commitees .env.local)
# 3. En Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Base de datos (PostgreSQL — cualquier proveedor) ──────────
# El código es provider-agnostic: solo necesita una URL PostgreSQL estándar.
# Proveedores recomendados: Neon (neon.tech), Supabase, Railway, Render.
#
# Neon  → Project → Dashboard → Connection String (URI)
# Local → postgresql://postgres:password@localhost:5432/dojomanager
#
# IMPORTANTE: incluye ?sslmode=require para conexiones remotas.
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dojomanager?sslmode=require"

# Pool máximo de conexiones. Dejar en 1 para serverless (Vercel/Netlify).
# Cambiar a 10+ solo si usas un servidor dedicado (VPS, Docker, etc.).
# DATABASE_POOL_MAX=1

# ── NextAuth ──────────────────────────────────────────────────
# Generar secreto: openssl rand -base64 32
NEXTAUTH_SECRET="GENERAR_CON_OPENSSL_RAND_BASE64_32"
# URL de la aplicación. En local: http://localhost:3000
NEXTAUTH_URL="https://tu-app.vercel.app"

# ── Cifrado AES-256 para credenciales sensibles ───────────────
# Generar: node -e "require('crypto').randomBytes(32).toString('base64')|console.log"
# CRÍTICO: si pierdes esta clave, las contraseñas SMTP cifradas no se podrán descifrar.
# Guárdala en un gestor de contraseñas (1Password, Bitwarden, etc.)
ENCRYPTION_KEY="GENERAR_32_BYTES_BASE64"

# ── Email (fallback — configurable desde la UI del sistema) ───
# Estos valores se usan si no hay configuración SMTP guardada en la BD.
# Para Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal).
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="correo@dominio.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Dojo Master <correo@dominio.com>"

# ── Cloudinary (almacenamiento de fotos y videos) ─────────────
# Crear cuenta en https://cloudinary.com (plan Free: 25 GB + 25 GB/mes)
# Copiar desde: Cloudinary Dashboard → API Keys
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"   # Mantener SOLO en servidor, nunca en el cliente

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Dojo Master"
NEXT_PUBLIC_APP_URL="https://tu-app.vercel.app"

# ── Sentry — monitoreo de errores ──────────────────────────────
# Crear proyecto en https://sentry.io → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@oXXXXXX.ingest.us.sentry.io/XXXXXX"

# Opcionales — solo necesarios para subir source maps en el build (stack traces legibles en prod)
# Sentry → Settings → Auth Tokens (scope: project:releases)
# SENTRY_ORG="tu-org"
# SENTRY_PROJECT="tu-proyecto"
# SENTRY_AUTH_TOKEN="GENERAR_EN_SENTRY"
