// ════════════════════════════════════════════════════════════════════════════
// MÓDULO ASISTENCIA A TORNEOS — independiente de Torneo Pro y de asistencia
// diaria. dojoId y studentId son strings sin FK formal para no modificar
// modelos existentes. Aislamiento multi-tenant enforced en las APIs.
// ════════════════════════════════════════════════════════════════════════════

model TournamentEvent {
  id        String   @id @default(cuid())
  dojoId    String   @map("dojo_id")        // dojo propietario — SIEMPRE presente
  name      String                           // nombre del torneo
  date      DateTime                         // fecha del evento
  location  String                           // sede/lugar
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  participants TournamentEventParticipant[]

  @@index([dojoId])
  @@index([dojoId, date])
  @@map("tournament_events")
}

model TournamentEventParticipant {
  id        String @id @default(cuid())
  eventId   String @map("event_id")
  studentId String @map("student_id")   // sin FK formal — no modifica Student

  // ── Asistencia ─────────────────────────────────────────────────
  arrived   Boolean   @default(false)
  arrivedAt DateTime? @map("arrived_at")
  scannedBy String?   @map("scanned_by")   // nombre del usuario que escaneó

  // ── Resultados ─────────────────────────────────────────────────
  category     String? @map("category")        // categoría de competencia (ej: "Cadete -57kg")
  kataName     String? @map("kata_name")       // kata ejecutado
  kataResult   String? @map("kata_result")     // ej: "1° Lugar", "Medalla de Oro"
  kumiteResult String? @map("kumite_result")   // ej: "Medalla de Bronce"
  competitionNotes String? @db.Text @map("competition_notes")

  // IDs de los registros en KataCompetition (para actualizar en lugar de duplicar)
  kataCompetitionId    String? @map("kata_competition_id")
  kumiteCompetitionId  String? @map("kumite_competition_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  event TournamentEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@index([eventId])
  @@index([studentId])
  @@index([eventId, arrived])
  @@index([eventId, kataResult])
  @@map("tournament_event_participants")
}

// ════════════════════════════════════════════════════════════════════════════
// AUTO-REGISTRO — Links de auto-inscripción + cola de aprobación
// ════════════════════════════════════════════════════════════════════════════

model RegistrationLink {
  id          String    @id @default(cuid())
  dojoId      String    @map("dojo_id")
  dojo        Dojo      @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  token       String    @unique           // crypto.randomUUID() — 122 bits de entropía
  label       String                      // "Inscripciones Enero 2026"
  isActive    Boolean   @default(true)    @map("is_active")
  activatesAt DateTime? @map("activates_at")  // no usable ANTES de esta fecha
  expiresAt   DateTime? @map("expires_at")    // no usable DESPUÉS de esta fecha
  maxUses     Int?      @map("max_uses")       // null = sin límite
  useCount    Int       @default(0)        @map("use_count")
  createdAt   DateTime  @default(now())    @map("created_at")
  createdBy   String    @map("created_by") // userId del admin

  pendingStudents PendingStudent[]

  @@index([dojoId])
  @@map("registration_links")
}

model PendingStudent {
  id                 String           @id @default(cuid())
  dojoId             String           @map("dojo_id")
  dojo               Dojo             @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  registrationLinkId String           @map("registration_link_id")
  registrationLink   RegistrationLink @relation(fields: [registrationLinkId], references: [id], onDelete: Cascade)

  // ── Datos personales ────────────────────────────────────────
  fullName   String   @map("full_name")
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  birthDate  DateTime @map("birth_date")
  gender     String
  nationality String
  cedula     String?
  fepakaId   String?  @map("fepaka_id")
  ryoBukaiId String?  @map("ryo_bukai_id")

  // ── Datos de salud ──────────────────────────────────────────
  bloodType           String?  @map("blood_type")
  condition           String?
  hasPrivateInsurance Boolean  @default(false) @map("has_private_insurance")
  insuranceName       String?  @map("insurance_name")
  insuranceNumber     String?  @map("insurance_number")

  // ── Contactos ───────────────────────────────────────────────
  motherName  String?  @map("mother_name")
  motherPhone String?  @map("mother_phone")
  motherEmail String?  @map("mother_email")
  fatherName  String?  @map("father_name")
  fatherPhone String?  @map("father_phone")
  fatherEmail String?  @map("father_email")
  address     String?  @db.Text
  photo       String?  @db.Text   // base64 — se copia a Student al aprobar

  // ── Contexto familiar ───────────────────────────────────────
  hasSiblingInDojo Boolean @default(false) @map("has_sibling_in_dojo")
  primaryGuardian  String? @map("primary_guardian")  // "mother" | "father" — acudiente principal para acceso al portal

  // ── Control de aprobación ───────────────────────────────────
  status        String    @default("pending")  // pending | approved | rejected
  reviewedBy    String?   @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  rejectionNote String?   @map("rejection_note")
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  submitterIp   String?   @map("submitter_ip")
  resetToken    String?   @unique @map("reset_token") // token de un solo uso para re-envío autorizado por admin

  @@index([dojoId, status])
  @@index([registrationLinkId])
  @@map("pending_students")
}

// ════════════════════════════════════════════════════════════════════════════
// BILLING — Planes, Suscripciones y Facturas
// ════════════════════════════════════════════════════════════════════════════

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  READ_ONLY
  COMPLIMENTARY   // acceso completo permanente sin pago
  SPECIAL_ACCESS  // acceso especial con fecha de expiración configurable
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum PaymentGateway {
  PAYPAL
  MERCADOPAGO
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Plan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  monthlyPrice    Float    @map("monthly_price")
  annualPrice     Float    @map("annual_price")
  maxStudents     Int?     @map("max_students")
  features        String                          // JSON array de strings
  isActive        Boolean  @default(true)         @map("is_active")
  paypalProductId String?  @map("paypal_product_id")
  createdAt       DateTime @default(now())        @map("created_at")

  subscriptions   Subscription[]

  @@index([isActive])
  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  dojoId               String             @unique @map("dojo_id")
  dojo                 Dojo               @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  planId               String             @map("plan_id")
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIAL)
  cycle                BillingCycle       @default(MONTHLY)
  trialEndsAt          DateTime           @map("trial_ends_at")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  gateway              PaymentGateway?
  paypalSubscriptionId String?            @map("paypal_subscription_id")
  paypalCustomerId     String?            @map("paypal_customer_id")
  mpSubscriptionId     String?            @map("mp_subscription_id")
  mpCustomerId         String?            @map("mp_customer_id")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  // Acceso especial otorgado por sysadmin
  grantedBy            String?            @map("granted_by")   // email del sysadmin
  grantedAt            DateTime?          @map("granted_at")   // fecha del otorgamiento
  grantNote            String?            @map("grant_note")   // motivo/nota interna
  createdAt            DateTime           @default(now())  @map("created_at")
  updatedAt            DateTime           @updatedAt       @map("updated_at")

  invoices             Invoice[]

  @@index([status])
  @@index([trialEndsAt])
  @@map("subscriptions")
}

model Invoice {
  id               String         @id @default(cuid())
  subscriptionId   String         @map("subscription_id")
  subscription     Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  dojoId           String         @map("dojo_id")
  amount           Float
  currency         String         @default("USD")
  status           InvoiceStatus  @default(PENDING)
  gateway          PaymentGateway
  gatewayInvoiceId String?        @map("gateway_invoice_id")
  paidAt           DateTime?      @map("paid_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([dojoId])
  @@index([status])
  @@map("invoices")
}

// Log de correos de aviso de vencimiento de acceso especial
model SpecialAccessEmailLog {
  id       String   @id @default(cuid())
  dojoId   String   @map("dojo_id")
  dojo     Dojo     @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  email    String
  daysLeft Int      @map("days_left")
  status   String   // "sent" | "failed"
  error    String?
  sentAt   DateTime @default(now()) @map("sent_at")

  @@index([dojoId])
  @@index([sentAt])
  @@map("special_access_email_logs")
}

// ════════════════════════════════════════════════════════════════════════════
// MÓDULO EXÁMENES Y CERTIFICADOS
// ════════════════════════════════════════════════════════════════════════════

model ExamApplication {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  title       String
  location    String
  examDate    DateTime @map("exam_date")
  examTime    String   @map("exam_time")
  deadline    DateTime?
  amount      Float    @default(0)
  description String?  @db.Text
  status      String    @default("DRAFT")
  archivedAt  DateTime? @map("archived_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  dojo     Dojo                     @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  invitees ExamApplicationInvitee[]

  @@index([dojoId, status])
  @@index([dojoId, examDate])
  @@index([dojoId, archivedAt])
  @@map("exam_applications")
}

model ExamApplicationInvitee {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  studentId       String   @map("student_id")
  beltToPresent   String   @map("belt_to_present")
  response        String   @default("PENDING")
  responseNote    String?  @db.Text @map("response_note")
  respondedAt     DateTime? @map("responded_at")
  paymentStatus   String   @default("PENDING") @map("payment_status")
  paidAt          DateTime? @map("paid_at")
  attended        Boolean  @default(false)
  passed          Boolean?
  createdAt       DateTime @default(now()) @map("created_at")

  application  ExamApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student      Student               @relation(fields: [studentId], references: [id], onDelete: Restrict)
  certificate  GeneratedCertificate?

  @@unique([applicationId, studentId])
  @@index([studentId])
  @@index([applicationId, response])
  @@map("exam_application_invitees")
}

model CertificateTemplate {
  id            String   @id @default(cuid())
  dojoId        String   @map("dojo_id")
  name          String
  imageUrl      String   @db.Text @map("image_url")
  imagePublicId String   @map("image_public_id")
  canvasWidth   Int      @default(1000) @map("canvas_width")
  canvasHeight  Int      @default(700)  @map("canvas_height")
  elements      Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dojo         Dojo                   @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  certificates GeneratedCertificate[]

  @@index([dojoId, active])
  @@map("certificate_templates")
}

model GeneratedCertificate {
  id             String   @id @default(cuid())
  dojoId         String   @map("dojo_id")
  studentId      String   @map("student_id")
  inviteeId      String?  @unique @map("invitee_id")
  templateId     String   @map("template_id")
  title          String
  beltColor      String   @map("belt_color")
  issuedDate     DateTime @map("issued_date")
  instructorName String?  @map("instructor_name")
  pdfUrl         String?  @db.Text @map("pdf_url")
  pdfPublicId    String?  @map("pdf_public_id")
  status         String   @default("DRAFT")
  revokedReason  String?  @db.Text @map("revoked_reason")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime @default(now()) @map("created_at")

  dojo     Dojo                    @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  student  Student                 @relation(fields: [studentId], references: [id], onDelete: Restrict)
  invitee  ExamApplicationInvitee? @relation(fields: [inviteeId], references: [id], onDelete: SetNull)
  template CertificateTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([dojoId, status])
  @@index([dojoId, beltColor])
  @@map("generated_certificates")
}
