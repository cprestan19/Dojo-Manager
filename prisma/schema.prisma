// Schema: DojoManager — SaaS de gestión de dojos de karate
// Desarrollado por Cristhian Paul Prestán — 2025

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dojo {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?  @db.Text
  ownerName String?
  phone     String?
  slogan    String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Parámetros de recordatorios de pago
  reminderToleranceDays Int     @default(5)
  lateInterestPct       Float   @default(10.0)
  autoRemindersEnabled  Boolean @default(false)
  loginBgImage    String? @db.Text @map("login_bg_image")
  contractPolicy  String? @db.Text @map("contract_policy")  // texto de políticas/contrato mostrado en el auto-registro
  instagramUrl  String? @map("instagram_url")
  themeId       String  @default("dark-saas") @map("theme_id")
  locale        String  @default("es")        @map("locale")       // "es" | "en"
  tournamentPro Boolean @default(false)       @map("tournament_pro") // Módulo Torneo Pro activado

  // Colores de marca para el carnet digital del alumno (hex). null = paleta roja/negra por defecto.
  cardPrimaryColor   String? @map("card_primary_color")
  cardSecondaryColor String? @map("card_secondary_color")
  cardTertiaryColor  String? @map("card_tertiary_color")
  cardTemplateImage  String? @db.Text @map("card_template_image")
  cardLayout         Json?              @map("card_layout")
  cardLayout2        Json?              @map("card_layout_2")
  cardTemplateImage2 String? @db.Text  @map("card_template_image_2")
  cardLayout3        Json?              @map("card_layout_3")
  cardTemplateImage3 String? @db.Text  @map("card_template_image_3")
  activeCardSlot     Int      @default(1) @map("active_card_slot")

  users           User[]
  students        Student[]
  katas           Kata[]
  schedules       Schedule[]
  beltVideos      BeltVideo[]
  rolePermissions DojoRolePermission[]
  dojoPage        DojoPage?
  freeTrials      FreeTrialRequest[]
  tournaments     Tournament[]
  tournamentTatamis       TournamentTatami[]
  tournamentJudges        TournamentJudge[]
  tournamentScheduleSlots TournamentScheduleSlot[]
  tournamentStreams        TournamentStream[]
  tournamentRegistrations TournamentRegistration[]
  events                  Event[]
  storeProducts           StoreProduct[]
  organizations           DojoOrganization[]
  externalClubs           ExternalClub[]
  externalAthletes        ExternalAthlete[]
  subscription            Subscription?
  registrationLinks       RegistrationLink[]
  pendingStudents         PendingStudent[]
  specialAccessEmailLogs  SpecialAccessEmailLog[]
  examApplications      ExamApplication[]
  certificateTemplates  CertificateTemplate[]
  generatedCertificates GeneratedCertificate[]

  @@map("dojos")
}

// ── Organizations / federations the dojo belongs to ─────────
model DojoOrganization {
  id      String @id @default(cuid())
  dojoId  String @map("dojo_id")
  dojo    Dojo   @relation(fields: [dojoId], references: [id], onDelete: Cascade)

  name    String
  logoUrl String? @map("logo_url") @db.Text  // Cloudinary URL
  order   Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dojoId])
  @@map("dojo_organizations")
}

// ── Public website content for each dojo ────────────────────
model DojoPage {
  id        String  @id @default(cuid())
  dojoId    String  @unique @map("dojo_id")
  dojo      Dojo    @relation(fields: [dojoId], references: [id], onDelete: Cascade)

  published   Boolean @default(false)

  // Hero section
  heroTitle    String? @map("hero_title")
  heroSubtitle String? @map("hero_subtitle")
  heroImage    String? @map("hero_image") @db.Text  // Cloudinary URL — fondo del hero

  // About section
  aboutText  String? @db.Text @map("about_text")
  aboutImage String? @map("about_image") @db.Text  // Cloudinary URL

  // Theme
  primaryColor String @default("#C0392B") @map("primary_color")

  // Visibility toggles
  showFreeTrial  Boolean @default(true)  @map("show_free_trial")
  showSchedules  Boolean @default(true)  @map("show_schedules")
  showContact    Boolean @default(true)  @map("show_contact")
  showStore      Boolean @default(false) @map("show_store")

  // Ubicación
  address String? @db.Text  // dirección física del dojo

  // Galería de atletas — array JSON de URLs Cloudinary
  galleryImages Json?   @map("gallery_images")

  // Perfil del Sensei {name, rank, experience, bio, photo}
  sensei        Json?

  // Barra de estadísticas [{value:"150+", label:"Alumnos formados"}, ...]
  stats         Json?

  // Testimonios [{name, role, quote, photo?}, ...]
  testimonials  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dojo_pages")
}

// ── Free trial / scholarship requests ───────────────────────
model FreeTrialRequest {
  id     String @id @default(cuid())
  dojoId String @map("dojo_id")
  dojo   Dojo   @relation(fields: [dojoId], references: [id], onDelete: Cascade)

  // Child info
  childName  String @map("child_name")
  childAge   Int    @map("child_age")

  // Parent / guardian
  parentName  String  @map("parent_name")
  parentPhone String  @map("parent_phone")
  parentEmail String? @map("parent_email")
  message     String? @db.Text

  // Status flow: pending → contacted → scheduled → enrolled | cancelled
  status String @default("pending")

  // Assigned schedule (set by admin after review)
  scheduleId String?   @map("schedule_id")
  schedule   Schedule? @relation(fields: [scheduleId], references: [id])

  read     Boolean  @default(false)  // admin has seen it
  notes    String?  @db.Text         // admin internal notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dojoId])
  @@index([dojoId, status])
  @@index([dojoId, read])
  @@map("free_trial_requests")
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role               String   @default("user")   // sysadmin, admin, user, student
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  photo     String?  @db.Text

  dojoId    String?  @map("dojo_id")
  dojo      Dojo?    @relation(fields: [dojoId], references: [id])

  studentId String?  @unique @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id])

  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  @@index([email])
  @@index([dojoId])
  @@index([dojoId, active])      // filter active users within a dojo
  @@index([dojoId, role])        // count/filter by role within a dojo (last-sysadmin checks)
  @@map("users")
}

model Student {
  id          String   @id @default(cuid())
  studentCode Int?     @unique
  cardToken   String?  @unique @map("card_token") // token impredecible para /id/[code] (carnet público)

  dojoId    String   @map("dojo_id")
  dojo      Dojo     @relation(fields: [dojoId], references: [id])

  fullName   String   @default("") @map("full_name")
  firstName  String
  lastName   String
  cedula       String?
  fepakaId     String?  @map("fepaka_id")
  ryoBukaiId   String?  @map("ryo_bukai_id")
  photo        String?  @db.Text
  birthDate  DateTime
  gender     String
  nationality String

  condition           String?
  bloodType           String?  @map("blood_type")
  hasPrivateInsurance Boolean  @default(false)
  insuranceName       String?
  insuranceNumber     String?  @map("insurance_number")

  motherName  String?
  motherPhone String?
  motherEmail String?

  fatherName  String?
  fatherPhone String?
  fatherEmail String?

  primaryGuardian String? @map("primary_guardian")  // "mother" | "father" — acudiente principal para acceso al portal

  address String? @db.Text
  familyId  String?  @map("family_id")

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Absence risk level — updated when attendance is recorded or via batch recalculation.
  // ACTIVO  : attended within last 3 days
  // ALERTA  : 3–13 days without attendance  (risk of disengagement)
  // RIESGO  : 14+ days without attendance  (high dropout risk)
  attendanceStatus String @default("ACTIVO") @map("attendance_status")

  portalUser                User?
  inscription               Inscription?
  payments                  Payment[]
  beltHistory               BeltHistory[]
  attendances               Attendance[]
  studentSchedules          StudentSchedule[]
  kataCompetitions          KataCompetition[]
  tournamentParticipations  TournamentParticipant[]
  tournamentRegistrations   TournamentRegistration[]
  eventRsvps                EventRSVP[]
  examInvitees          ExamApplicationInvitee[]
  certificates          GeneratedCertificate[]

  @@index([dojoId, active])
  @@index([dojoId, lastName, firstName])
  @@index([dojoId, fullName])
  @@index([dojoId, active, fullName])
  @@index([familyId])
  @@map("students")
}

model Inscription {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  inscriptionDate   DateTime
  annualPaymentDate DateTime?

  annualAmount   Float  @default(0)
  monthlyAmount  Float  @default(0)
  discountAmount Float  @default(0)
  discountNote   String?

  // Pago quincenal (cada 15 días — 1° y 15 de cada mes)
  // paymentPeriod defaults to "monthly" so existing students are unaffected.
  paymentPeriod  String @default("monthly") @map("payment_period")  // monthly | biweekly
  biweeklyAmount Float  @default(0)          @map("biweekly_amount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inscriptions")
}

model Payment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  type     String
  amount   Float
  dueDate  DateTime
  paidDate DateTime?

  status       String  @default("pending")
  note         String?
  reminderSent Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([studentId, type, dueDate])
  @@index([studentId])
  @@index([studentId, status, dueDate])
  @@index([status, dueDate])
  @@index([reminderSent, status, dueDate])
  @@map("payments")
}

model Kata {
  id          String  @id @default(cuid())
  name        String
  beltColor   String
  order       Int     @default(0)
  description String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())

  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])

  beltHistory      BeltHistory[]
  kataCompetitions KataCompetition[]

  @@unique([name, dojoId])
  @@index([dojoId])
  @@index([beltColor])
  @@index([dojoId, active])      // GET /api/katas?active=1 filtered by dojo
  @@map("katas")
}

model BeltHistory {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  beltColor  String
  changeDate DateTime
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  kataIds    Json?    @map("kata_ids")   // array de hasta 5 IDs para cintas roja–negra-3-dan
  isRanking  Boolean  @default(false)
  notes      String?

  createdAt DateTime @default(now())

  @@index([studentId, changeDate])
  @@map("belt_history")
}

model Schedule {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  name        String
  days        String
  startTime   String
  endTime     String
  description String?
  active              Boolean  @default(true)
  availableForTrial   Boolean  @default(false) @map("available_for_trial")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attendances      Attendance[]
  studentSchedules StudentSchedule[]
  freeTrials       FreeTrialRequest[]
  @@index([dojoId])
  @@index([dojoId, active])
  @@map("schedules")
}

model Attendance {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId  String?
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  type        String
  markedAt    DateTime  @default(now())
  note        String?
  corrected   Boolean   @default(false)
  correctedBy String?
  createdAt   DateTime  @default(now())
  @@index([studentId, markedAt])
  @@index([scheduleId, markedAt])
  @@index([studentId, type, markedAt])  // duplicate-entry check: WHERE studentId=? AND type=? AND markedAt >= ?
  @@map("attendances")
}

model StudentSchedule {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId String
  schedule   Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  @@index([studentId])
  @@index([scheduleId])
  @@index([assignedAt])
  @@index([studentId, removedAt])  // active assignments: WHERE studentId=? AND removedAt IS NULL
  @@map("student_schedules")
}

model AuditLog {
  id        String   @id @default(cuid())

  // ── Qué se hizo ─────────────────────────────────────────────
  action       String                    // LOGIN_FAILED | STUDENT_CREATED | PAYMENT_MARKED_PAID | ...
  module       String?                   // AUTH | STUDENTS | PAYMENTS | BELTS | ATTENDANCE | USERS | SETTINGS | SYSADMIN | TOURNAMENTS | PORTAL
  method       String?                   // GET | POST | PUT | PATCH | DELETE
  resourceType String?  @map("resource_type")  // Student | User | Payment | BeltHistory | Dojo | Tournament
  resourceId   String?  @map("resource_id")    // ID del registro afectado
  statusCode   Int?     @map("status_code")    // Código HTTP del resultado: 200 | 201 | 400 | 401 | 403 | 500

  // ── Quién lo hizo ────────────────────────────────────────────
  userId           String?
  userName         String?  @map("user_name")          // Nombre del actor
  userEmail        String?
  isSysadminProxy  Boolean  @default(false) @map("is_sysadmin_proxy")  // sysadmin operando en dojo ajeno

  // ── Dónde ────────────────────────────────────────────────────
  dojoId    String?
  dojoSlug  String?

  // ── Sobre quién / qué ────────────────────────────────────────
  targetId    String?  @map("target_id")     // ID del usuario o recurso objetivo
  targetEmail String?  @map("target_email")  // Email del objetivo (acciones sobre usuarios)

  // ── Red, dispositivo y geolocalización ───────────────────────
  ip        String?
  userAgent String?  @db.Text
  country   String?             // Código ISO del país (ES, PA, CO) via headers Vercel/Cloudflare
  city      String?             // Ciudad del usuario
  region    String?             // Región/estado

  // ── Sesión y correlación ──────────────────────────────────────
  sessionId String?  @map("session_id")  // UUID fijo por sesión — correlaciona todos los eventos del mismo login

  // ── Rendimiento y contexto ───────────────────────────────────
  duration  Int?      // Duración de la operación en ms
  details   String?  @db.Text  // JSON: { before, after, reason, extra }

  // ── Integridad ────────────────────────────────────────────────
  hash      String?  @db.Text  // SHA-256 de los campos clave — detecta tampering del log

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([resourceType, resourceId])
  @@index([ip])
  @@index([sessionId])
  @@index([createdAt])
  @@index([dojoId, createdAt])
  @@map("audit_logs")
}

model EmailSettings {
  id        String   @id @default("singleton")
  host      String   @default("")
  port      Int      @default(587)
  user      String   @default("")
  password  String   @default("")
  secure    Boolean  @default(false)
  fromName  String   @default("DojoManager")
  updatedAt DateTime @updatedAt
  @@map("email_settings")
}

model DojoRolePermission {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  roleName    String   @map("role_name")
  roleLabel   String   @map("role_label")
  roleColor   String   @default("blue") @map("role_color")
  isSystem    Boolean  @default(false)  @map("is_system")
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dojoId, roleName])
  @@index([dojoId])
  @@map("dojo_role_permissions")
}

model BeltVideo {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  beltColor   String   @map("belt_color")
  title       String
  description String?  @db.Text
  videoUrl          String?  @map("video_url")
  publicId          String?  @map("public_id")
  tachiKataUrl      String?  @map("tachi_kata_url")
  tachiKataPublicId String?  @map("tachi_kata_public_id")
  order             Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dojoId])
  @@index([dojoId, beltColor])
  @@map("belt_videos")
}

model KataCompetition {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  date       DateTime
  tournament String?
  result     String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([date])
  @@map("kata_competitions")
}

model Tournament {
  id           String    @id @default(cuid())
  dojoId       String    @map("dojo_id")
  dojo         Dojo      @relation(fields: [dojoId], references: [id])
  name         String
  date         DateTime
  location     String
  organization String
  leader1      String
  leader2      String?
  leader3      String?
  tatami       Int?
  scheduledAt  DateTime? @map("scheduled_at")

  description  String?   @db.Text
  format       String?   @db.Text @map("tournament_format")
  arbitrage    String?   @db.Text
  requirements String?   @db.Text
  contact      String?   @db.Text
  flyerImage   String?   @db.Text @map("flyer_image")
  // draft | ready | active | completed | confirmed
  status       String    @default("draft")
  bracketLocked Boolean  @default(false) @map("bracket_locked")
  archivedAt   DateTime? @map("archived_at")   // null = activo, fecha = inactivo/historial
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  registrationOpenAt  DateTime? @map("registration_open_at")
  registrationCloseAt DateTime? @map("registration_close_at")
  venue               String?
  city                String?
  country             String?
  maxParticipants     Int?      @map("max_participants")
  isPublic            Boolean   @default(false) @map("is_public")
  publicSlug          String?   @unique @map("public_slug")
  bracketsLockedAt    DateTime? @map("brackets_locked_at")
  bracketsLockedBy    String?   @map("brackets_locked_by")
  organizerName       String?   @map("organizer_name")
  organizerEmail      String?   @map("organizer_email")
  organizerPhone      String?   @map("organizer_phone")
  rules               String?   @db.Text

  // ── Torneos abiertos / federados ────────────────────────────
  // "internal" = solo alumnos del dojo | "open" = clubs externos | "federated" = con federación
  tournamentType      String    @default("internal")  @map("tournament_type")
  entryFeePerCategory Float?    @map("entry_fee_per_category")
  feeCurrency         String    @default("USD")       @map("fee_currency")
  requirePhoto        Boolean   @default(false)       @map("require_photo")
  requireFederationId Boolean   @default(false)       @map("require_federation_id")
  requireWaiver       Boolean   @default(true)        @map("require_waiver")
  waiverText          String?   @db.Text              @map("waiver_text")
  maxAthletesPerClub  Int?      @map("max_athletes_per_club")
  maxTotalAthletes    Int?      @map("max_total_athletes")

  // ── Acreditación ─────────────────────────────────────────────
  // PIN 4-6 dígitos para voluntarios en la entrada — NUNCA exponer en APIs públicas
  accreditationPin    String?   @map("accreditation_pin")

  participants    TournamentParticipant[]
  matches         TournamentMatch[]
  referees        TournamentReferee[]
  brackets        TournamentBracket[]
  externalClubs   ExternalClub[]
  externalAthletes ExternalAthlete[]

  @@index([dojoId])
  @@index([dojoId, status])
  @@map("tournaments")
}

model TournamentBracket {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  type         String    @default("kumite") @map("bracket_type")   // "kumite" | "kata"
  gender       String?   @map("gender")                             // "M" | "F" | null
  order        Int        @default(0)
  bracketLocked       Boolean   @default(false) @map("bracket_locked")
  // draft | ready | active | completed
  status              String    @default("draft")
  bracketScheduledAt  DateTime? @map("bracket_scheduled_at")
  bracketTatami       Int?      @map("bracket_tatami")

  // ── Categoría WKF ────────────────────────────────────────────
  // "mini_4_5"|"mini_6_7"|"infantil_a"|"infantil_b"|"pre_cadete"|"cadete"|"junior"|"sub21"|"senior"|"master35"|"master45"|"open"
  ageGroup       String?   @map("age_group")
  // "-50kg"|"-55kg"|"-60kg"|"-61kg"|"-67kg"|"-68kg"|"-75kg"|"-84kg"|"+84kg"|"open" — null para kata
  weightCategory String?   @map("weight_category")
  // "principiantes"|"intermedios"|"avanzados"|"elite" — para torneos por cinta
  beltCategory   String?   @map("belt_category")
  // true = Kata en Equipo (3 atletas por equipo)
  isTeamKata     Boolean   @default(false) @map("is_team_kata")
  // Auto-generado por buildCategoryLabel() — "Kumite Cadete -63kg Masculino"
  categoryLabel  String?   @map("category_label")
  // Orden de disputa en el tatami
  bracketOrder   Int       @default(0) @map("bracket_order")

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  participants             TournamentParticipant[]
  matches                  TournamentMatch[]
  externalAthleteCategories ExternalAthleteCategory[]

  @@index([tournamentId])
  @@index([tournamentId, status])
  @@map("tournament_brackets")
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  studentId    String     @map("student_id")
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  bracketId    String?    @map("bracket_id")
  bracket      TournamentBracket? @relation(fields: [bracketId], references: [id], onDelete: SetNull)
  seed         Int        @default(0)
  weight       Float?     @map("weight")   // peso en kg del competidor (para overlay de TV)

  // ── QR de acreditación ───────────────────────────────────────
  // Solo se genera cuando tournament.status = ready|active Y admin confirma lista
  qrCode           String?   @unique @map("qr_code")
  accreditedAt     DateTime? @map("accredited_at")
  credentialSentAt DateTime? @map("credential_sent_at")
  kikenAt          DateTime? @map("kiken_at")   // solo árbitro admin puede setearlo

  createdAt    DateTime   @default(now())

  @@unique([bracketId, studentId])
  @@index([tournamentId])
  @@index([studentId])
  @@index([bracketId])
  @@index([bracketId, tournamentId])
  @@index([qrCode])
  @@map("tournament_participants")
}

model TournamentMatch {
  id             String     @id @default(cuid())
  tournamentId   String     @map("tournament_id")
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bracketId      String?    @map("bracket_id")
  bracket        TournamentBracket? @relation(fields: [bracketId], references: [id], onDelete: SetNull)
  tatamiId       String?    @map("tatami_id")
  tatami         TournamentTatami? @relation("TatamiMatches", fields: [tatamiId], references: [id], onDelete: SetNull)
  round          Int
  matchNumber    Int        @map("match_number")
  participant1Id String?    @map("participant1_id")
  participant2Id String?    @map("participant2_id")
  score1         Int?       @map("score1")
  score2         Int?       @map("score2")
  winnerId       String?    @map("winner_id")
  isBye          Boolean    @default(false) @map("is_bye")
  senshu         String?    @map("senshu") // participantId del primer anotador (desempate)

  // ── Hantei (判定) — decisión por empate ───────────────────────
  // "none" | "called" | "voting" | "decided"
  hanteiStatus     String    @default("none")  @map("hantei_status")
  hanteiWinnerId   String?   @map("hantei_winner_id")
  hanteiVotesAo    Int       @default(0)       @map("hantei_votes_ao")
  hanteiVotesAka   Int       @default(0)       @map("hantei_votes_aka")
  hanteiCalledAt   DateTime? @map("hantei_called_at")
  hanteiDecidedAt  DateTime? @map("hantei_decided_at")

  // ── Video Review ─────────────────────────────────────────────
  // "none" | "requested" | "reviewing" | "confirmed" | "reversed"
  reviewStatus       String    @default("none")  @map("review_status")
  reviewRequestedAt  DateTime? @map("review_requested_at")
  reviewRequestedBy  String?   @map("review_requested_by")  // "ao"|"aka"|"referee"
  reviewDecision     String?   @map("review_decision")      // "confirmed"|"reversed"|"no_contest"
  reviewNotes        String?   @db.Text @map("review_notes")
  reviewCompletedAt  DateTime? @map("review_completed_at")

  judgeScores    TournamentJudgeScore[]

  @@unique([bracketId, round, matchNumber])
  @@index([tournamentId, round])
  @@index([bracketId])
  @@index([tatamiId])
  @@index([tatamiId, winnerId])
  @@index([tournamentId, bracketId, round, matchNumber])
  @@index([tournamentId, round, matchNumber])
  @@map("tournament_matches")
}

// ── Puntuación individual por juez ───────────────────────────
model TournamentJudgeScore {
  id           String           @id @default(cuid())
  matchId      String           @map("match_id")
  match        TournamentMatch  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  judgeId      String           @map("judge_id")
  judge        TournamentJudge  @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  tatamiId     String?          @map("tatami_id")
  tatami       TournamentTatami? @relation(fields: [tatamiId], references: [id], onDelete: SetNull)

  // Kumite: puntos enteros | Kata: decimales (ej. 8.5)
  scoreType    String  @default("kumite") @map("score_type")  // "kumite" | "kata"

  // Kumite: técnicas individuales (para pantalla de TV)
  ippon1       Int     @default(0) @map("ippon1")     // 3 pts cada uno
  wazaari1     Int     @default(0) @map("wazaari1")   // 2 pts
  yuko1        Int     @default(0) @map("yuko1")      // 1 pt
  ippon2       Int     @default(0) @map("ippon2")
  wazaari2     Int     @default(0) @map("wazaari2")
  yuko2        Int     @default(0) @map("yuko2")

  // Kumite: total calculado (= ippon*3 + wazaari*2 + yuko*1)
  score1       Float   @default(0) @map("score1")
  score2       Float   @default(0) @map("score2")

  // Kumite: penalizaciones — chukoku(C)/hansoku(H)
  chukoku1     Int     @default(0) @map("chukoku1")   // advertencia leve
  hansoku1     Int     @default(0) @map("hansoku1")   // descalificación
  chukoku2     Int     @default(0) @map("chukoku2")
  hansoku2     Int     @default(0) @map("hansoku2")
  penalty1     Int     @default(0) @map("penalty1")   // total penalizaciones C1
  penalty2     Int     @default(0) @map("penalty2")   // total penalizaciones C2

  // Última técnica registrada (para mostrar en TV)
  lastTechnique1 String? @map("last_technique1")  // "ippon"|"wazaari"|"yuko"|"chukoku"|"hansoku"
  lastTechnique2 String? @map("last_technique2")

  // Kata: nota del juez (ej. 8.5)
  kataScore1   Float?  @map("kata_score1")
  kataScore2   Float?  @map("kata_score2")

  updatedAt    DateTime @updatedAt

  @@unique([matchId, judgeId])
  @@index([matchId])
  @@index([judgeId])
  @@index([tatamiId])
  @@map("tournament_judge_scores")
}

model TournamentEmailLog {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  studentId    String?  @map("student_id")
  email        String
  status       String   // sent | failed
  error        String?
  sentAt       DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_email_logs")
}

model TournamentReferee {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  order        Int        @default(0)

  @@index([tournamentId])
  @@map("tournament_referees")
}

model TournamentTatami {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  dojoId       String   @map("dojo_id")
  dojo         Dojo     @relation(fields: [dojoId], references: [id])
  name         String
  order        Int      @default(0)
  color        String   @default("#C0392B")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // ── Streaming por tatami ──────────────────────────────────
  youtubeVideoId   String? @map("youtube_video_id")
  youtubeStreamKey String? @db.Text @map("youtube_stream_key")
  streamStatus     String  @default("offline") @map("stream_status") // offline|live|finished
  overlayMessage   String? @db.Text @map("overlay_message")

  // ── Match activo en este tatami (para overlay y scoreboard) ──
  currentMatchId        String?   @map("current_match_id")
  currentMatchStartedAt DateTime? @map("current_match_started_at") // marca de inicio del Sencho
  matchTimerRunning     Boolean   @default(false) @map("match_timer_running")
  matchTimerBaseElapsed Int       @default(0)     @map("match_timer_base_elapsed") // segundos acumulados antes de la última pausa
  matchDurationSecs     Int       @default(120)   @map("match_duration_secs")      // duración total del match en segundos (default 2:00)

  // ── Display TV — máquina de estados ──────────────────────────
  // "idle" | "active" | "winner" | "next_preview"
  matchDisplayState   String    @default("idle")  @map("match_display_state")
  winnerParticipantId String?   @map("winner_participant_id")
  // "points"|"ippon"|"wazaari"|"hansoku"|"kiken"|"senshu"
  winnerReason        String?   @map("winner_reason")
  // Al setearse, la pantalla TV inicia cuenta regresiva 10s → next_preview automáticamente
  matchWonAt          DateTime? @map("match_won_at")

  // ── Video Review ─────────────────────────────────────────────
  videoReviewEnabled Boolean @default(false) @map("video_review_enabled")
  // Ruta donde OBS graba el archivo local — solo informativo, el sistema NO accede al FS
  obsRecordingPath   String? @map("obs_recording_path")
  // Segundos desde el inicio del match cuando se solicitó la última revisión
  lastReviewOffset   Int?    @map("last_review_offset")

  // ── Overlay OBS parametrizable ───────────────────────────────
  // "1920x1080"|"1280x720"|"3840x2160"|"1080x1920"|"1366x768"
  overlayPreset  String @default("1920x1080") @map("overlay_preset")
  overlayWidth   Int    @default(1920)         @map("overlay_width")
  overlayHeight  Int    @default(1080)         @map("overlay_height")
  overlayScale   Float  @default(1.0)          @map("overlay_scale")

  judges        TournamentJudge[]
  scheduleSlots TournamentScheduleSlot[]
  matches       TournamentMatch[]        @relation("TatamiMatches")
  judgeScores   TournamentJudgeScore[]

  @@index([tournamentId])
  @@index([dojoId])
  @@map("tournament_tatamis")
}

model TournamentJudge {
