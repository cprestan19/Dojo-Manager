// ── Clubs externos (torneos abiertos) ───────────────────────
model ExternalClub {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  dojoId       String   @map("dojo_id")        // dojo anfitrión — SIEMPRE

  clubName     String   @map("club_name")
  country      String?
  city         String?
  coachName    String   @map("coach_name")
  coachEmail   String   @map("coach_email")
  coachPhone   String?  @map("coach_phone")
  federationId String?  @map("federation_id")

  // JWT firmado 30 días — NUNCA retornar al organizador
  accessToken   String   @unique @map("access_token")
  accessExpires DateTime @map("access_expires")

  // "pending"|"approved"|"rejected"|"waitlist"
  status          String    @default("pending")
  approvedAt      DateTime? @map("approved_at")
  approvedBy      String?   @map("approved_by")
  rejectionReason String?   @db.Text @map("rejection_reason")

  // "unpaid"|"partial"|"paid"|"waived"
  paymentStatus   String    @default("unpaid") @map("payment_status")
  paymentRef      String?   @map("payment_ref")
  paymentProofUrl String?   @db.Text @map("payment_proof_url")  // URL Cloudinary
  paymentNotes    String?   @db.Text @map("payment_notes")
  paidAt          DateTime? @map("paid_at")

  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  dojo       Dojo              @relation(fields: [dojoId], references: [id])
  athletes   ExternalAthlete[]

  @@index([tournamentId])
  @@index([dojoId])
  @@index([coachEmail])
  @@index([accessToken])
  @@map("external_clubs")
}

// ── Atletas de clubs externos ────────────────────────────────
model ExternalAthlete {
  id             String   @id @default(cuid())
  tournamentId   String   @map("tournament_id")
  dojoId         String   @map("dojo_id")         // dojo anfitrión — SIEMPRE
  externalClubId String   @map("external_club_id")

  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  documentId  String?  @map("document_id")        // NUNCA incluir en listas
  birthDate   DateTime @map("birth_date")
  gender      String                               // "M"|"F"
  nationality String?                              // código ISO "PA","CO","MX"
  weight      Float?
  beltColor   String?  @map("belt_color")
  fepakaId    String?  @map("fepaka_id")
  photoUrl    String?  @db.Text @map("photo_url") // URL Cloudinary

  // Calculado al guardar con calculateAgeGroup()
  ageGroup    String?  @map("age_group")

  // "pending"|"approved"|"rejected"|"withdrawn"
  status      String   @default("pending")

  waiverSigned   Boolean   @default(false) @map("waiver_signed")
  waiverSignedAt DateTime? @map("waiver_signed_at")
  waiverIp       String?   @map("waiver_ip")

  // QR de acreditación — solo cuando club.status=approved Y paymentStatus=paid|waived
  qrCode           String?   @unique @map("qr_code")
  accreditedAt     DateTime? @map("accredited_at")
  credentialSentAt DateTime? @map("credential_sent_at")
  kikenAt          DateTime? @map("kiken_at")

  // Bracket asignado post-aprobación (sin FK formal — solo referencia)
  bracketId   String?  @map("bracket_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tournament   Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  dojo         Dojo          @relation(fields: [dojoId], references: [id])
  externalClub ExternalClub  @relation(fields: [externalClubId], references: [id], onDelete: Cascade)
  categories   ExternalAthleteCategory[]

  @@index([tournamentId])
  @@index([dojoId])
  @@index([externalClubId])
  @@index([externalClubId, status])
  @@index([qrCode])
  @@map("external_athletes")
}

// ── Inscripciones por categoría de atleta externo ───────────
model ExternalAthleteCategory {
  id           String @id @default(cuid())
  tournamentId String @map("tournament_id")
  dojoId       String @map("dojo_id")         // dojo anfitrión — SIEMPRE
  athleteId    String @map("athlete_id")

  // Sin FK formal en bracketId para no crear relación inversa en TournamentBracket legacy
  bracketId     String? @map("bracket_id")
  categoryLabel String  @map("category_label")  // "Kumite Cadete -63kg Masculino"

  // "pending"|"approved"|"rejected"|"waitlist"|"withdrawn"
  status          String  @default("pending")
  rejectionReason String? @db.Text @map("rejection_reason")

  feeAmount     Float?  @map("fee_amount")
  // "unpaid"|"paid"|"waived"
  paymentStatus String  @default("unpaid") @map("payment_status")

  // Ranking/seeding
  isRanking        Boolean  @default(false) @map("is_ranking")       // coach lo marca al inscribir
  rankingValidated Boolean? @map("ranking_validated")                 // null=pendiente, true/false=decisión
  rankingNote      String?  @db.Text @map("ranking_note")            // coach: "Campeón Nac. 2024"
  rankingSeed      Int?     @map("ranking_seed")                      // organizador asigna: 1-4

  bracketSeed     Int? @map("bracket_seed")
  bracketPosition Int? @map("bracket_position")

  approvedAt DateTime? @map("approved_at")
  approvedBy String?   @map("approved_by")

  athlete ExternalAthlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  bracket TournamentBracket? @relation(fields: [bracketId], references: [id], onDelete: SetNull)

  @@index([tournamentId])
  @@index([dojoId])
  @@index([athleteId])
  @@index([bracketId])
  @@map("external_athlete_categories")
}

// ── Hantei votes ─────────────────────────────────────────────
model HanteiVote {
