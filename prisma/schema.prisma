// Schema: DojoManager — SaaS de gestión de dojos de karate
// Desarrollado por Cristhian Paul Prestán — 2025

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dojo {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?  @db.Text
  ownerName String?
  phone     String?
  slogan    String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Parámetros de recordatorios de pago
  reminderToleranceDays Int     @default(5)
  lateInterestPct       Float   @default(10.0)
  autoRemindersEnabled  Boolean @default(false)
  loginBgImage  String? @db.Text @map("login_bg_image")
  instagramUrl  String? @map("instagram_url")
  themeId       String  @default("dark-saas") @map("theme_id")

  users           User[]
  students        Student[]
  katas           Kata[]
  schedules       Schedule[]
  beltVideos      BeltVideo[]
  rolePermissions DojoRolePermission[]
  dojoPage        DojoPage?
  freeTrials      FreeTrialRequest[]
  tournaments     Tournament[]
  tournamentTatamis       TournamentTatami[]
  tournamentJudges        TournamentJudge[]
  tournamentScheduleSlots TournamentScheduleSlot[]
  tournamentStreams        TournamentStream[]
  tournamentRegistrations TournamentRegistration[]
  events                  Event[]
  storeProducts           StoreProduct[]

  @@map("dojos")
}

// ── Public website content for each dojo ────────────────────
model DojoPage {
  id        String  @id @default(cuid())
  dojoId    String  @unique @map("dojo_id")
  dojo      Dojo    @relation(fields: [dojoId], references: [id], onDelete: Cascade)

  published   Boolean @default(false)

  // Hero section
  heroTitle    String? @map("hero_title")
  heroSubtitle String? @map("hero_subtitle")
  heroImage    String? @map("hero_image") @db.Text  // Cloudinary URL — fondo del hero

  // About section
  aboutText  String? @db.Text @map("about_text")
  aboutImage String? @map("about_image") @db.Text  // Cloudinary URL

  // Theme
  primaryColor String @default("#C0392B") @map("primary_color")

  // Visibility toggles
  showFreeTrial  Boolean @default(true)  @map("show_free_trial")
  showSchedules  Boolean @default(true)  @map("show_schedules")
  showContact    Boolean @default(true)  @map("show_contact")
  showStore      Boolean @default(false) @map("show_store")

  // Ubicación
  address String? @db.Text  // dirección física del dojo

  // Galería de atletas — array JSON de URLs Cloudinary
  galleryImages Json?   @map("gallery_images")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dojo_pages")
}

// ── Free trial / scholarship requests ───────────────────────
model FreeTrialRequest {
  id     String @id @default(cuid())
  dojoId String @map("dojo_id")
  dojo   Dojo   @relation(fields: [dojoId], references: [id], onDelete: Cascade)

  // Child info
  childName  String @map("child_name")
  childAge   Int    @map("child_age")

  // Parent / guardian
  parentName  String  @map("parent_name")
  parentPhone String  @map("parent_phone")
  parentEmail String? @map("parent_email")
  message     String? @db.Text

  // Status flow: pending → contacted → scheduled → enrolled | cancelled
  status String @default("pending")

  // Assigned schedule (set by admin after review)
  scheduleId String?   @map("schedule_id")
  schedule   Schedule? @relation(fields: [scheduleId], references: [id])

  read     Boolean  @default(false)  // admin has seen it
  notes    String?  @db.Text         // admin internal notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dojoId])
  @@index([dojoId, status])
  @@index([dojoId, read])
  @@map("free_trial_requests")
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role               String   @default("user")   // sysadmin, admin, user, student
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  photo     String?  @db.Text

  dojoId    String?  @map("dojo_id")
  dojo      Dojo?    @relation(fields: [dojoId], references: [id])

  studentId String?  @unique @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id])

  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  @@index([email])
  @@index([dojoId])
  @@index([dojoId, active])      // filter active users within a dojo
  @@index([dojoId, role])        // count/filter by role within a dojo (last-sysadmin checks)
  @@map("users")
}

model Student {
  id          String   @id @default(cuid())
  studentCode Int?     @unique

  dojoId    String   @map("dojo_id")
  dojo      Dojo     @relation(fields: [dojoId], references: [id])

  fullName   String   @default("") @map("full_name")
  firstName  String
  lastName   String
  cedula       String?
  fepakaId     String?  @map("fepaka_id")
  ryoBukaiId   String?  @map("ryo_bukai_id")
  photo        String?  @db.Text
  birthDate  DateTime
  gender     String
  nationality String

  condition           String?
  bloodType           String?  @map("blood_type")
  hasPrivateInsurance Boolean  @default(false)
  insuranceName       String?
  insuranceNumber     String?  @map("insurance_number")

  motherName  String?
  motherPhone String?
  motherEmail String?

  fatherName  String?
  fatherPhone String?
  fatherEmail String?

  address String? @db.Text

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Absence risk level — updated when attendance is recorded or via batch recalculation.
  // ACTIVO  : attended within last 3 days
  // ALERTA  : 3–13 days without attendance  (risk of disengagement)
  // RIESGO  : 14+ days without attendance  (high dropout risk)
  attendanceStatus String @default("ACTIVO") @map("attendance_status")

  portalUser                User?
  inscription               Inscription?
  payments                  Payment[]
  beltHistory               BeltHistory[]
  attendances               Attendance[]
  studentSchedules          StudentSchedule[]
  kataCompetitions          KataCompetition[]
  tournamentParticipations  TournamentParticipant[]
  tournamentRegistrations   TournamentRegistration[]

  @@index([dojoId, active])
  @@index([dojoId, lastName, firstName])
  @@index([dojoId, fullName])
  @@index([dojoId, active, fullName])
  @@map("students")
}

model Inscription {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  inscriptionDate   DateTime
  annualPaymentDate DateTime?

  annualAmount   Float  @default(0)
  monthlyAmount  Float  @default(0)
  discountAmount Float  @default(0)
  discountNote   String?

  // Pago quincenal (cada 15 días — 1° y 15 de cada mes)
  // paymentPeriod defaults to "monthly" so existing students are unaffected.
  paymentPeriod  String @default("monthly") @map("payment_period")  // monthly | biweekly
  biweeklyAmount Float  @default(0)          @map("biweekly_amount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inscriptions")
}

model Payment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  type     String
  amount   Float
  dueDate  DateTime
  paidDate DateTime?

  status       String  @default("pending")
  note         String?
  reminderSent Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([studentId, type, dueDate])
  @@index([studentId])
  @@index([studentId, status, dueDate])
  @@index([status, dueDate])
  @@index([reminderSent, status, dueDate])
  @@map("payments")
}

model Kata {
  id          String  @id @default(cuid())
  name        String
  beltColor   String
  order       Int     @default(0)
  description String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())

  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])

  beltHistory      BeltHistory[]
  kataCompetitions KataCompetition[]

  @@unique([name, dojoId])
  @@index([dojoId])
  @@index([beltColor])
  @@index([dojoId, active])      // GET /api/katas?active=1 filtered by dojo
  @@map("katas")
}

model BeltHistory {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  beltColor  String
  changeDate DateTime
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  kataIds    Json?    @map("kata_ids")   // array de hasta 5 IDs para cintas roja–negra-3-dan
  isRanking  Boolean  @default(false)
  notes      String?

  createdAt DateTime @default(now())

  @@index([studentId, changeDate])
  @@map("belt_history")
}

model Schedule {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  name        String
  days        String
  startTime   String
  endTime     String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attendances      Attendance[]
  studentSchedules StudentSchedule[]
  freeTrials       FreeTrialRequest[]
  @@index([dojoId])
  @@index([dojoId, active])
  @@map("schedules")
}

model Attendance {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId  String?
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  type        String
  markedAt    DateTime  @default(now())
  note        String?
  corrected   Boolean   @default(false)
  correctedBy String?
  createdAt   DateTime  @default(now())
  @@index([studentId, markedAt])
  @@index([scheduleId, markedAt])
  @@index([studentId, type, markedAt])  // duplicate-entry check: WHERE studentId=? AND type=? AND markedAt >= ?
  @@map("attendances")
}

model StudentSchedule {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduleId String
  schedule   Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  @@index([studentId])
  @@index([scheduleId])
  @@index([assignedAt])
  @@index([studentId, removedAt])  // active assignments: WHERE studentId=? AND removedAt IS NULL
  @@map("student_schedules")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  userEmail String?
  dojoId    String?
  dojoSlug  String?
  ip        String?
  userAgent String?  @db.Text
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model EmailSettings {
  id        String   @id @default("singleton")
  host      String   @default("")
  port      Int      @default(587)
  user      String   @default("")
  password  String   @default("")
  secure    Boolean  @default(false)
  fromName  String   @default("DojoManager")
  updatedAt DateTime @updatedAt
  @@map("email_settings")
}

model DojoRolePermission {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  roleName    String   @map("role_name")
  roleLabel   String   @map("role_label")
  roleColor   String   @default("blue") @map("role_color")
  isSystem    Boolean  @default(false)  @map("is_system")
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dojoId, roleName])
  @@index([dojoId])
  @@map("dojo_role_permissions")
}

model BeltVideo {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id])
  beltColor   String   @map("belt_color")
  title       String
  description String?  @db.Text
  videoUrl    String   @map("video_url")
  publicId    String   @map("public_id")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dojoId])
  @@index([dojoId, beltColor])
  @@map("belt_videos")
}

model KataCompetition {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kataId     String?
  kata       Kata?    @relation(fields: [kataId], references: [id])
  date       DateTime
  tournament String?
  result     String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([date])
  @@map("kata_competitions")
}

model Tournament {
  id           String    @id @default(cuid())
  dojoId       String    @map("dojo_id")
  dojo         Dojo      @relation(fields: [dojoId], references: [id])
  name         String
  date         DateTime
  location     String
  organization String
  leader1      String
  leader2      String?
  leader3      String?
  tatami       Int?
  scheduledAt  DateTime? @map("scheduled_at")

  description  String?   @db.Text
  format       String?   @db.Text @map("tournament_format")
  arbitrage    String?   @db.Text
  requirements String?   @db.Text
  contact      String?   @db.Text
  flyerImage   String?   @db.Text @map("flyer_image")
  // draft | ready | active | completed | confirmed
  status       String    @default("draft")
  bracketLocked Boolean  @default(false) @map("bracket_locked")
  archivedAt   DateTime? @map("archived_at")   // null = activo, fecha = inactivo/historial
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  registrationOpenAt  DateTime? @map("registration_open_at")
  registrationCloseAt DateTime? @map("registration_close_at")
  venue               String?
  city                String?
  country             String?
  maxParticipants     Int?      @map("max_participants")
  isPublic            Boolean   @default(false) @map("is_public")
  publicSlug          String?   @unique @map("public_slug")
  bracketsLockedAt    DateTime? @map("brackets_locked_at")
  bracketsLockedBy    String?   @map("brackets_locked_by")
  organizerName       String?   @map("organizer_name")
  organizerEmail      String?   @map("organizer_email")
  organizerPhone      String?   @map("organizer_phone")
  rules               String?   @db.Text

  participants TournamentParticipant[]
  matches      TournamentMatch[]
  referees     TournamentReferee[]
  brackets     TournamentBracket[]

  @@index([dojoId])
  @@index([dojoId, status])
  @@map("tournaments")
}

model TournamentBracket {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  type         String    @default("kumite") @map("bracket_type")   // "kumite" | "kata"
  gender       String?   @map("gender")                             // "M" | "F" | null
  order        Int        @default(0)
  bracketLocked       Boolean   @default(false) @map("bracket_locked")
  // draft | ready | active | completed
  status              String    @default("draft")
  bracketScheduledAt  DateTime? @map("bracket_scheduled_at")
  bracketTatami       Int?      @map("bracket_tatami")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  participants TournamentParticipant[]
  matches      TournamentMatch[]

  @@index([tournamentId])
  @@map("tournament_brackets")
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  studentId    String     @map("student_id")
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  bracketId    String?    @map("bracket_id")
  bracket      TournamentBracket? @relation(fields: [bracketId], references: [id], onDelete: SetNull)
  seed         Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([bracketId, studentId])
  @@index([tournamentId])
  @@index([studentId])
  @@index([bracketId])
  @@index([bracketId, tournamentId])
  @@map("tournament_participants")
}

model TournamentMatch {
  id             String     @id @default(cuid())
  tournamentId   String     @map("tournament_id")
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bracketId      String?    @map("bracket_id")
  bracket        TournamentBracket? @relation(fields: [bracketId], references: [id], onDelete: SetNull)
  round          Int
  matchNumber    Int        @map("match_number")
  participant1Id String?    @map("participant1_id")
  participant2Id String?    @map("participant2_id")
  score1         Int?       @map("score1")
  score2         Int?       @map("score2")
  winnerId       String?    @map("winner_id")
  isBye          Boolean    @default(false) @map("is_bye")

  // Unicidad: no pueden existir dos matches con mismo round+matchNumber en el mismo bracket
  @@unique([bracketId, round, matchNumber])
  @@index([tournamentId, round])
  @@index([bracketId])
  @@index([tournamentId, bracketId, round, matchNumber])
  @@index([tournamentId, round, matchNumber])
  @@map("tournament_matches")
}

model TournamentEmailLog {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  studentId    String?  @map("student_id")
  email        String
  status       String   // sent | failed
  error        String?
  sentAt       DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_email_logs")
}

model TournamentReferee {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  order        Int        @default(0)

  @@index([tournamentId])
  @@map("tournament_referees")
}

model TournamentTatami {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  dojoId       String   @map("dojo_id")
  dojo         Dojo     @relation(fields: [dojoId], references: [id])
  name         String
  order        Int      @default(0)
  color        String   @default("#C0392B")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  judges       TournamentJudge[]
  scheduleSlots TournamentScheduleSlot[]
  @@index([tournamentId])
  @@index([dojoId])
  @@map("tournament_tatamis")
}

model TournamentJudge {
  id           String            @id @default(cuid())
  tournamentId String            @map("tournament_id")
  dojoId       String            @map("dojo_id")
  dojo         Dojo              @relation(fields: [dojoId], references: [id])
  tatamiId     String?           @map("tatami_id")
  tatami       TournamentTatami? @relation(fields: [tatamiId], references: [id])
  name         String
  role         String            @default("judge")
  licenseNo    String?           @map("license_no")
  nationality  String?
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  @@index([tournamentId])
  @@index([dojoId])
  @@map("tournament_judges")
}

model TournamentScheduleSlot {
  id           String            @id @default(cuid())
  tournamentId String            @map("tournament_id")
  dojoId       String            @map("dojo_id")
  dojo         Dojo              @relation(fields: [dojoId], references: [id])
  tatamiId     String?           @map("tatami_id")
  tatami       TournamentTatami? @relation(fields: [tatamiId], references: [id])
  startTime    String            @map("start_time")
  endTime      String?           @map("end_time")
  eventType    String            @map("event_type")
  title        String
  description  String?
  order        Int               @default(0)
  createdAt    DateTime          @default(now())
  @@index([tournamentId])
  @@index([dojoId])
  @@map("tournament_schedule_slots")
}

model TournamentStream {
  id              String    @id @default(cuid())
  tournamentId    String    @unique @map("tournament_id")
  dojoId          String    @map("dojo_id")
  dojo            Dojo      @relation(fields: [dojoId], references: [id])
  youtubeVideoId  String?   @map("youtube_video_id")
  youtubeStreamKey String?  @db.Text @map("youtube_stream_key")
  title           String?
  description     String?   @db.Text
  thumbnailUrl    String?   @map("thumbnail_url")
  status          String    @default("offline")
  overlayMessage  String?   @map("overlay_message")
  activeOverlay   String    @default("logo") @map("active_overlay")
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([dojoId])
  @@map("tournament_streams")
}

model TournamentRegistration {
  id             String    @id @default(cuid())
  tournamentId   String    @map("tournament_id")
  dojoId         String    @map("dojo_id")
  dojo           Dojo      @relation(fields: [dojoId], references: [id])
  studentId      String?   @map("student_id")
  student        Student?  @relation(fields: [studentId], references: [id])
  guestFirstName String?   @map("guest_first_name")
  guestLastName  String?   @map("guest_last_name")
  guestDojo      String?   @map("guest_dojo")
  guestBelt      String?   @map("guest_belt")
  guestBirthDate DateTime? @map("guest_birth_date")
  guestEmail     String?   @map("guest_email")
  guestPhone     String?   @map("guest_phone")
  categories     String
  status         String    @default("pending")
  approvedAt     DateTime? @map("approved_at")
  approvedBy     String?   @map("approved_by")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([tournamentId])
  @@index([dojoId])
  @@map("tournament_registrations")
}

// ── Eventos del dojo ─────────────────────────────────────────
model Event {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  location    String?
  imageUrl    String?  @map("image_url") @db.Text
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@index([dojoId])
  @@index([dojoId, endDate])
  @@map("events")
}

// ── Tienda del dojo ──────────────────────────────────────────
model StoreProduct {
  id          String   @id @default(cuid())
  dojoId      String   @map("dojo_id")
  dojo        Dojo     @relation(fields: [dojoId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  price       Float
  currency    String   @default("USD")
  imageUrl    String?  @map("image_url") @db.Text
  sizes       Json?    // string[] — ["XS","S","M","L","XL"] o null si no aplica
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@index([dojoId])
  @@index([dojoId, active])
  @@map("store_products")
}
